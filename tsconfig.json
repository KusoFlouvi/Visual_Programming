{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "types": ["vitest/globals"]
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "**/*.file3.ts", "vitest.config.ts"]
}